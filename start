        { giorno: 40, titolo: "Contemplazione e comunità", riferimenti: ["Galati 5:22-26"], testo: ["22 Il frutto dello Spirito invece è amore, gioia, pace, pazienza, benignità, bontà, fedeltà,", "23 mansuetudine, autocontrollo; contro queste cose non c'è legge.", "24 Coloro che sono di Cristo hanno crocifisso la carne con le sue passioni e i suoi desideri.", "25 Se viviamo per lo Spirito, camminiamo anche secondo lo Spirito.", "26 Non cerchiamo la vanagloria, provocandoci gli uni gli altri, invidiandoci a vicenda."] }
    ];

    // ============================================================
    //  STATO
    // ============================================================
    let currentDay = 1;
    let fontSize = 1.1;
    let checkedDays = new Set();

    try {
        const saved = localStorage.getItem('checkedDays');
        if (saved) {
            const arr = JSON.parse(saved);
            checkedDays = new Set(arr);
        }
    } catch(e) {}

    // ============================================================
    //  DOM REFS
    // ============================================================
    const dayStrip = document.getElementById('dayStrip');
    const detailContainer = document.getElementById('day-detail');
    const darkToggle = document.getElementById('darkToggle');
    const notesModal = document.getElementById('notesModal');
    const openNotesBtn = document.getElementById('openNotesBtn');
    const closeNotesBtn = document.getElementById('closeNotesModal');
    const notesList = document.getElementById('notesList');
    const fontInc = document.getElementById('fontInc');
    const fontDec = document.getElementById('fontDec');

    // ============================================================
    //  FUNZIONI
    // ============================================================

    function saveCheckedDays() {
        localStorage.setItem('checkedDays', JSON.stringify([...checkedDays]));
    }

    function toggleCheck(giorno) {
        if (checkedDays.has(giorno)) {
            checkedDays.delete(giorno);
        } else {
            checkedDays.add(giorno);
        }
        saveCheckedDays();
        updateDayButtons();
        updateCheckButton();
    }

    function updateDayButtons() {
        document.querySelectorAll('.day-btn').forEach(btn => {
            const g = parseInt(btn.dataset.giorno);
            btn.classList.toggle('checked', checkedDays.has(g));
        });
    }

    function updateCheckButton() {
        const btn = document.getElementById('checkToggleBtn');
        if (!btn) return;
        const isChecked = checkedDays.has(currentDay);
        btn.classList.toggle('is-checked', isChecked);
        btn.textContent = isChecked ? '✅ Segnato' : '☐ Segna come letto';
    }

    // --- Gestione font size ---
    function changeFontSize(delta) {
        fontSize = Math.min(1.8, Math.max(0.8, fontSize + delta));
        const bibleEl = document.getElementById('bibleText');
        if (bibleEl) bibleEl.style.fontSize = fontSize + 'rem';
        // Aggiorna anche le note (textarea) – il font-size è ereditato, ma forziamo
        const noteText = document.getElementById('noteText');
        if (noteText) noteText.style.fontSize = fontSize + 'rem';
        // modale note – verrà aggiornata al prossimo apertura
    }

    // --- RENDER STRISCIA GIORNI ---
    function renderDayStrip() {
        dayStrip.innerHTML = '';
        days.forEach(d => {
            const btn = document.createElement('button');
            btn.className = 'day-btn';
            if (d.giorno === currentDay) btn.classList.add('active');
            if (checkedDays.has(d.giorno)) btn.classList.add('checked');
            btn.textContent = d.giorno;
            btn.dataset.giorno = d.giorno;
            btn.addEventListener('click', () => selectDay(d.giorno));
            dayStrip.appendChild(btn);
        });
        const activeBtn = dayStrip.querySelector('.day-btn.active');
        if (activeBtn) {
            activeBtn.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
        }
    }

    function selectDay(giorno) {
        currentDay = giorno;
        document.querySelectorAll('.day-btn').forEach(btn => {
            btn.classList.toggle('active', parseInt(btn.dataset.giorno) === giorno);
        });
        renderDayDetail(giorno);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function renderDayDetail(giorno) {
        const dayData = days.find(d => d.giorno === giorno);
        if (!dayData) return;

        const savedNote = localStorage.getItem(`note_${giorno}`) || '';
        const isChecked = checkedDays.has(giorno);

        let html = `
            <div class="detail-header">
                <div class="day-number">Giorno ${dayData.giorno}</div>
                <h2>${dayData.titolo}</h2>
                <div class="reference">${dayData.riferimenti.join(' — ')}</div>
            </div>

            <div class="bible-text" id="bibleText" style="font-size:${fontSize}rem;">
                ${dayData.testo.map(v => `<span class="versetto">${v}</span>`).join('')}
            </div>
            <div class="translation-note">Nuova Riveduta 2006</div>

            <div class="check-section">
                <button class="check-btn ${isChecked ? 'is-checked' : ''}" id="checkToggleBtn">
                    ${isChecked ? '✅ Segnato' : '☐ Segna come letto'}
                </button>
            </div>

            <div class="day-nav">
                <button id="prevDay" ${giorno === 1 ? 'disabled' : ''}>← Giorno ${giorno-1}</button>
                <button id="nextDay" ${giorno === days.length ? 'disabled' : ''}>Giorno ${giorno+1} →</button>
            </div>

            <div class="notes-section">
                <h3>📝 Riflessioni personali</h3>
                <textarea id="noteText" placeholder="Scrivi qui le tue riflessioni su questo passo..." style="font-size:${fontSize}rem;">${savedNote}</textarea>
                <div class="note-actions">
                    <button id="saveNote">💾 Salva nota</button>
                    <button class="clear-note" id="clearNote">🗑️ Cancella</button>
                    <span class="saved-indicator" id="savedIndicator">✓ Salvato</span>
                </div>
            </div>
        `;

        detailContainer.innerHTML = html;

        // Check button
        const checkBtn = document.getElementById('checkToggleBtn');
        if (checkBtn) {
            checkBtn.addEventListener('click', () => {
                toggleCheck(giorno);
                const isNowChecked = checkedDays.has(giorno);
                checkBtn.classList.toggle('is-checked', isNowChecked);
                checkBtn.textContent = isNowChecked ? '✅ Segnato' : '☐ Segna come letto';
            });
        }

        // Navigazione
        document.getElementById('prevDay')?.addEventListener('click', () => {
            if (currentDay > 1) selectDay(currentDay - 1);
        });
        document.getElementById('nextDay')?.addEventListener('click', () => {
            if (currentDay < days.length) selectDay(currentDay + 1);
        });

        // Note
        const noteText = document.getElementById('noteText');
        const saveBtn = document.getElementById('saveNote');
        const clearBtn = document.getElementById('clearNote');
        const indicator = document.getElementById('savedIndicator');

        function saveNote() {
            if (noteText) {
                localStorage.setItem(`note_${giorno}`, noteText.value);
                if (indicator) {
                    indicator.classList.add('show');
                    setTimeout(() => indicator.classList.remove('show'), 2000);
                }
            }
        }

        saveBtn?.addEventListener('click', saveNote);

        clearBtn?.addEventListener('click', () => {
            if (noteText) {
                noteText.value = '';
                localStorage.removeItem(`note_${giorno}`);
                if (indicator) {
                    indicator.textContent = '✓ Cancellato';
                    indicator.classList.add('show');
                    setTimeout(() => {
                        indicator.classList.remove('show');
                        indicator.textContent = '✓ Salvato';
                    }, 2000);
                }
            }
        });

        let saveTimeout;
        noteText?.addEventListener('input', () => {
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(saveNote, 600);
        });
    }

    // --- MODALE NOTE ---
    function renderAllNotes() {
        const items = [];
        days.forEach(d => {
            const note = localStorage.getItem(`note_${d.giorno}`);
            if (note && note.trim() !== '') {
                items.push({ giorno: d.giorno, titolo: d.titolo, testo: note.trim() });
            }
        });

        if (items.length === 0) {
            notesList.innerHTML = `<div class="empty-notes">📭 Nessuna riflessione salvata. Inizia a scrivere le tue note nei singoli giorni!</div>`;
            return;
        }

        notesList.innerHTML = items.map(item => `
            <div class="note-item">
                <div class="note-header">
                    <span class="day-label">Giorno ${item.giorno}</span>
                    <span class="title">${item.titolo}</span>
                </div>
                <div class="note-body">${item.testo.replace(/\n/g, '<br>')}</div>
            </div>
        `).join('');
    }

    function openNotesModal() {
        renderAllNotes();
        notesModal.classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function closeNotesModalFn() {
        notesModal.classList.remove('open');
        document.body.style.overflow = '';
    }

    // ============================================================
    //  EVENTI
    // ============================================================
    darkToggle.addEventListener('click', () => {
        document.body.classList.toggle('dark');
        darkToggle.textContent = document.body.classList.contains('dark') ? '☀️' : '🌙';
    });

    fontInc.addEventListener('click', () => changeFontSize(0.1));
    fontDec.addEventListener('click', () => changeFontSize(-0.1));

    openNotesBtn.addEventListener('click', openNotesModal);
    closeNotesBtn.addEventListener('click', closeNotesModalFn);
    notesModal.addEventListener('click', (e) => {
        if (e.target === notesModal) closeNotesModalFn();
    });

    // ============================================================
    //  AVVIO
    // ============================================================
    renderDayStrip();
    renderDayDetail(1);
</script>

</body>
</html>
